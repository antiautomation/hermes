# ── Brain ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Telegram (your existing bot) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot (lock it to you)
TELEGRAM_ALLOWED_USER_IDS=

# ── Google (3 Gmail accounts + Calendar share one OAuth client) ─────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# token files are created by the OAuth flow and live in ./tokens (gitignored)

# ── 4th mailbox (IMAP/SMTP) ─────────────────────────────────────────────
IMAP_HOST=
IMAP_USER=
IMAP_PASS=
SMTP_HOST=
SMTP_PORT=587

# ── Mercury (READ-ONLY token only) ──────────────────────────────────────
MERCURY_API_TOKEN=

# ── Odoo (odoo-sidekick profile) ────────────────────────────────────────
ODOO_URL=
ODOO_DB=
ODOO_USER=
ODOO_API_KEY=

# ── Fitbit (OAuth2) ─────────────────────────────────────────────────────
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# ── GoWa WhatsApp bridges ───────────────────────────────────────────────
GOWA_BASIC_AUTH=user:changeme
GOWA_WEBHOOK_URL=http://agent:8080/webhook/whatsapp
GOWA_WEBHOOK_SECRET=

# ── PaperclipAI instances (comma-separated base URLs + matching tokens) ──
PAPERCLIP_INSTANCES=
PAPERCLIP_TOKENS=

# ── Obsidian ────────────────────────────────────────────────────────────
OBSIDIAN_VAULT_PATH=/home/USER/vault
